{
    "manifest_version": 3,
    "name": "Fキー タブ操作",
    "version": "1.7.0",
    "description": "F1〜F6でタブ操作（閉じる・切替・リロード・復活）",
    "permissions": ["tabs", "sessions", "alarms", "nativeMessaging", "storage"],
    "commands": {
        "close-tab": {
            "description": "タブを閉じる (F1)"
        },
        "prev-tab": {
            "description": "前のタブ (F2)"
        },
        "next-tab": {
            "description": "次のタブ (F3)"
        },
        "reopen-tab": {
            "description": "閉じたタブを復活 (F6)"
        },
"reload-tab": {
            "description": "リロード (F5)"
        },
        "hard-reload-tab": {
            "description": "強制リロード (Shift+F5)"
        }
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Fキー タブ操作"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": true
        }
    ]
}
